<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/imgBg"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        android:src="@drawable/splash_bg_2"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardCreateUser"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="18dp"
        android:layout_marginEnd="18dp"
        android:layout_marginTop="70dp"
        android:layout_marginBottom="90dp"
        app:cardCornerRadius="22dp"
        app:cardElevation="12dp"
        app:cardUseCompatPadding="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="18dp"
            android:background="#F3F5F6">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/back"
                android:contentDescription="Volver"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Crear usuario"
                android:textStyle="bold"
                android:textSize="22sp"
                android:textColor="@color/textDark"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toEndOf="@id/btnBack"
                android:layout_marginStart="8dp"
                app:layout_constraintBottom_toBottomOf="@id/btnBack"/>

            <TextView
                android:id="@+id/tvNameLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nombre"
                android:textColor="@color/textDark"
                android:layout_marginTop="20dp"
                app:layout_constraintTop_toBottomOf="@id/tvTitle"
                app:layout_constraintStart_toStartOf="parent"/>

            <EditText
                android:id="@+id/etName"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_input_rounded"
                android:hint="Nombre"
                android:inputType="textPersonName"
                android:textColor="@color/textDark"
                android:textColorHint="#6B7280"
                app:layout_constraintTop_toBottomOf="@id/tvNameLabel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <TextView
                android:id="@+id/tvEmailLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Email"
                android:textColor="@color/textDark"
                android:layout_marginTop="14dp"
                app:layout_constraintTop_toBottomOf="@id/etName"
                app:layout_constraintStart_toStartOf="parent"/>

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_input_rounded"
                android:hint="example@example.com"
                android:inputType="textEmailAddress"
                android:textColor="@color/textDark"
                android:textColorHint="#6B7280"
                app:layout_constraintTop_toBottomOf="@id/tvEmailLabel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <TextView
                android:id="@+id/tvRoleLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rol"
                android:textColor="@color/textDark"
                android:layout_marginTop="14dp"
                app:layout_constraintTop_toBottomOf="@id/etEmail"
                app:layout_constraintStart_toStartOf="parent"/>

            <Spinner
                android:id="@+id/spRole"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_input_rounded"
                app:layout_constraintTop_toBottomOf="@id/tvRoleLabel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <TextView
                android:id="@+id/tvCommissionLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="% Comisión"
                android:textColor="@color/textDark"
                android:layout_marginTop="14dp"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/spRole"
                app:layout_constraintStart_toStartOf="parent"/>

            <EditText
                android:id="@+id/etCommissionPercent"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_input_rounded"
                android:hint="Ej: 3"
                android:inputType="numberDecimal"
                android:textColor="@color/textDark"
                android:textColorHint="#6B7280"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/tvCommissionLabel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="Guardar"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                app:cornerRadius="12dp"
                android:background="@drawable/bg_button_purple_gradient"
                app:backgroundTint="@null"
                android:layout_marginTop="18dp"
                app:layout_constraintTop_toBottomOf="@id/etCommissionPercent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <TextView
                android:id="@+id/tvHint"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Se enviará un correo para que el usuario cree su contraseña."
                android:textSize="12sp"
                android:textColor="#374151"
                android:gravity="center"
                android:layout_marginTop="10dp"
                app:layout_constraintTop_toBottomOf="@id/btnSave"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
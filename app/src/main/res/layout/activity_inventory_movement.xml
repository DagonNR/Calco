<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/imgBg"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        android:src="@drawable/splash_bg_2"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="18dp"
        android:layout_marginEnd="18dp"
        android:layout_marginTop="70dp"
        android:layout_marginBottom="90dp"
        app:cardCornerRadius="22dp"
        app:cardElevation="12dp"
        app:cardUseCompatPadding="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="18dp"
            android:background="#F3F5F6">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/back"
                android:contentDescription="Volver"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Movimiento"
                android:textColor="@color/textDark"
                android:textSize="22sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@id/btnBack"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvQuantityLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cantidad"
                android:textColor="@color/textDark"
                android:layout_marginTop="18dp"
                app:layout_constraintTop_toBottomOf="@id/tvTitle"
                app:layout_constraintStart_toStartOf="parent"/>

            <EditText
                android:id="@+id/etQuantity"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_input_rounded"
                android:hint="Ej: 15"
                android:inputType="number"
                app:layout_constraintTop_toBottomOf="@id/tvQuantityLabel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- unitCost solo para ENTRADA -->
            <TextView
                android:id="@+id/tvUnitCostLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Costo unitario (solo entrada)"
                android:textColor="@color/textDark"
                android:layout_marginTop="14dp"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/etQuantity"
                app:layout_constraintStart_toStartOf="parent"/>

            <EditText
                android:id="@+id/etUnitCost"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_input_rounded"
                android:hint="Ej: 12.50"
                android:inputType="numberDecimal"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/tvUnitCostLabel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- ADJUST: dirección + motivo -->
            <TextView
                android:id="@+id/tvAdjustTypeLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tipo de ajuste"
                android:textColor="@color/textDark"
                android:layout_marginTop="14dp"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/etUnitCost"
                app:layout_constraintStart_toStartOf="parent"/>

            <Spinner
                android:id="@+id/spAdjustDirection"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_input_rounded"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/tvAdjustTypeLabel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <TextView
                android:id="@+id/tvReasonLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Motivo (solo ajuste)"
                android:textColor="@color/textDark"
                android:layout_marginTop="14dp"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/spAdjustDirection"
                app:layout_constraintStart_toStartOf="parent"/>

            <EditText
                android:id="@+id/etReason"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_input_rounded"
                android:hint="Ej: Merma / Roto / Error"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/tvReasonLabel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <TextView
                android:id="@+id/tvNoteLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nota (opcional)"
                android:textColor="@color/textDark"
                android:layout_marginTop="14dp"
                app:layout_constraintTop_toBottomOf="@id/etReason"
                app:layout_constraintStart_toStartOf="parent"/>

            <EditText
                android:id="@+id/etNote"
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:background="@drawable/bg_input_rounded"
                android:hint="Opcional"
                android:gravity="top"
                android:inputType="textMultiLine"
                app:layout_constraintTop_toBottomOf="@id/tvNoteLabel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="Guardar"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                app:cornerRadius="12dp"
                android:background="@drawable/bg_button_purple_gradient"
                app:backgroundTint="@null"
                android:layout_marginTop="18dp"
                app:layout_constraintTop_toBottomOf="@id/etNote"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
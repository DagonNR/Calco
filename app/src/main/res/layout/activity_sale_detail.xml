<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/imgBg"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        android:src="@drawable/splash_bg"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardDetail"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="18dp"
        android:layout_marginEnd="18dp"
        android:layout_marginTop="70dp"
        android:layout_marginBottom="90dp"
        app:cardCornerRadius="22dp"
        app:cardElevation="12dp"
        app:cardUseCompatPadding="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="18dp"
            android:background="#F3F5F6">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@android:color/transparent"
                android:src="@drawable/back"
                android:contentDescription="Volver"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Detalle Venta"
                android:textColor="@color/textDark"
                android:textSize="22sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@id/btnBack"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvClientLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cliente"
                android:textColor="#9CA3AF"
                android:layout_marginTop="18dp"
                app:layout_constraintTop_toBottomOf="@id/tvTitle"
                app:layout_constraintStart_toStartOf="parent"/>

            <EditText
                android:id="@+id/etClient"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_input_rounded_disabled"
                android:enabled="false"
                android:hint="Cliente"
                app:layout_constraintTop_toBottomOf="@id/tvClientLabel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <TextView
                android:id="@+id/tvAmountLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Monto"
                android:textColor="#9CA3AF"
                android:layout_marginTop="14dp"
                app:layout_constraintTop_toBottomOf="@id/etClient"
                app:layout_constraintStart_toStartOf="parent"/>

            <EditText
                android:id="@+id/etAmount"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_input_rounded_disabled"
                android:enabled="false"
                android:hint="$0.00"
                app:layout_constraintTop_toBottomOf="@id/tvAmountLabel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <TextView
                android:id="@+id/tvDateLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fecha"
                android:textColor="#9CA3AF"
                android:layout_marginTop="14dp"
                app:layout_constraintTop_toBottomOf="@id/etAmount"
                app:layout_constraintStart_toStartOf="parent"/>

            <EditText
                android:id="@+id/etDate"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_input_rounded_disabled"
                android:enabled="false"
                android:hint="dd/MM/yy"
                app:layout_constraintTop_toBottomOf="@id/tvDateLabel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <TextView
                android:id="@+id/tvNoteLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nota"
                android:textColor="#9CA3AF"
                android:layout_marginTop="14dp"
                app:layout_constraintTop_toBottomOf="@id/etDate"
                app:layout_constraintStart_toStartOf="parent"/>

            <EditText
                android:id="@+id/etNote"
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:background="@drawable/bg_input_rounded_disabled"
                android:enabled="false"
                android:hint="(Sin nota)"
                android:gravity="top"
                app:layout_constraintTop_toBottomOf="@id/tvNoteLabel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReport"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="Reportar"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                app:cornerRadius="12dp"
                app:backgroundTint="#D61B1E"
                android:layout_marginTop="18dp"
                app:layout_constraintTop_toBottomOf="@id/etNote"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavSeller"
        android:layout_width="0dp"
        android:layout_height="62dp"
        android:background="@android:color/white"
        app:menu="@menu/menu_seller_bottom"
        app:itemIconTint="@color/primary"
        app:itemTextColor="@color/textDark"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="10dp"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_history_item">

    <TextView
        android:id="@+id/tvName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Coca 350 ml"
        android:textStyle="bold"
        android:textSize="14sp"
        android:textColor="@color/textDark"
        android:maxLines="2"
        android:ellipsize="end"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginLeft="10dp"/>

    <TextView
        android:id="@+id/tvBarcode"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Barcode: 7508973"
        android:textSize="12sp"
        android:textColor="#6B7280"
        app:layout_constraintStart_toStartOf="@id/tvName"
        app:layout_constraintTop_toBottomOf="@id/tvName"
        app:layout_constraintEnd_toStartOf="@id/btnGo"
        android:layout_marginTop="2dp"
        android:layout_marginEnd="10dp"/>

    <TextView
        android:id="@+id/tvStock"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Stock: 15"
        android:textStyle="bold"
        android:textSize="12sp"
        android:textColor="@color/textDark"
        app:layout_constraintEnd_toStartOf="@id/btnGo"
        app:layout_constraintTop_toTopOf="@id/tvName"
        android:layout_marginEnd="10dp"/>

    <TextView
        android:id="@+id/tvPrice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="$18.00"
        android:textStyle="bold"
        android:textSize="12sp"
        android:textColor="@color/textDark"
        app:layout_constraintEnd_toStartOf="@id/btnGo"
        app:layout_constraintTop_toBottomOf="@id/tvStock"
        android:layout_marginEnd="10dp"
        android:layout_marginTop="2dp"/>

    <ImageButton
        android:id="@+id/btnGo"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@android:color/transparent"
        android:src="@drawable/item_button"
        android:contentDescription="Ver"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
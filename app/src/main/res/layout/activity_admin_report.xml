<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/imgBg"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        android:src="@drawable/splash_bg_2"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvAppName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="Calco"
        android:textColor="@color/cardWhite"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvTotalLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Total Ventas"
        android:textColor="@color/cardWhite"
        android:textSize="13sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvAppName" />

    <TextView
        android:id="@+id/tvTotalAmount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="$0.00"
        android:textColor="@color/cardWhite"
        android:textSize="30sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTotalLabel" />

    <TextView
        android:id="@+id/tvBaseMonth"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="Mes"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTotalAmount" />

    <ImageView
        android:id="@+id/btnFilter"
        android:layout_width="26dp"
        android:layout_height="26dp"
        android:layout_marginEnd="32dp"
        android:contentDescription="Filtro"
        android:src="@drawable/filter_gray"
        app:layout_constraintTop_toTopOf="@id/tvTotalAmount"
        app:layout_constraintBottom_toBottomOf="@id/tvTotalAmount"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardMain"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_marginStart="18dp"
        android:layout_marginEnd="18dp"
        android:layout_marginBottom="82dp"
        app:cardCornerRadius="22dp"
        app:cardElevation="12dp"
        app:cardUseCompatPadding="true"
        app:layout_constraintTop_toBottomOf="@id/tvBaseMonth"
        app:layout_constraintBottom_toTopOf="@id/bottomNavAdmin"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="16dp"
            android:background="#F3F5F6">

            <!-- Contenedor del Donut (Círculo Completo Proporcional) -->
            <FrameLayout
                android:id="@+id/donutContainer"
                android:layout_width="210dp"
                android:layout_height="210dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:id="@+id/progressDonut"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    app:indicatorSize="180dp"
                    app:trackThickness="24dp"
                    app:trackColor="#EAB308"
                    app:indicatorColor="#22C55E"
                    app:trackCornerRadius="0dp"
                    app:indicatorDirectionCircular="clockwise"
                    android:progress="65" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Proporción"
                        android:textSize="12sp"
                        android:textColor="#9CA3AF"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ventas"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#6B7280"/>
                </LinearLayout>
            </FrameLayout>

            <!-- Card Mes Base (Verde) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardBase"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="4dp"
                app:layout_constraintTop_toBottomOf="@id/donutContainer"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/cardComp"
                app:layout_constraintWidth_percent="0.48">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <View
                        android:layout_width="8dp"
                        android:layout_height="24dp"
                        android:background="#22C55E"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="8dp">
                        <TextView
                            android:id="@+id/tvBaseLabelCard"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Mes base"
                            android:textSize="10sp"
                            android:textAllCaps="true"
                            android:textColor="#9CA3AF"/>
                        <TextView
                            android:id="@+id/tvBaseAmountCard"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="$0.00"
                            android:textStyle="bold"
                            android:textSize="13sp"
                            android:textColor="@color/textDark"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card Mes Comparación (Amarillo) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardComp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="4dp"
                app:layout_constraintTop_toBottomOf="@id/donutContainer"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/cardBase"
                app:layout_constraintWidth_percent="0.48">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <View
                        android:layout_width="8dp"
                        android:layout_height="24dp"
                        android:background="#EAB308"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="8dp">
                        <TextView
                            android:id="@+id/tvCompLabelCard"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Comparación"
                            android:textSize="10sp"
                            android:textAllCaps="true"
                            android:textColor="#9CA3AF"/>
                        <TextView
                            android:id="@+id/tvCompAmountCard"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="$0.00"
                            android:textStyle="bold"
                            android:textSize="13sp"
                            android:textColor="@color/textDark"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Comparativa -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDiff"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:layout_constraintTop_toBottomOf="@id/cardBase"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Comparativa (Base − Comparación)"
                        android:textSize="10sp"
                        android:textColor="#9CA3AF"
                        android:layout_marginBottom="4dp"/>
                    <TextView
                        android:id="@+id/tvDiffAmount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-$0.00"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="#B91C1C"/>
                    <TextView
                        android:id="@+id/tvDiffPercent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-0.0%"
                        android:textSize="12sp"
                        android:textColor="#B91C1C"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSalesList"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:text="Lista de ventas"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_button_purple_gradient"
                app:backgroundTint="@null"
                app:elevation="6dp"
                app:layout_constraintTop_toBottomOf="@id/cardDiff"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnExportPdf"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:text="Exportar a PDF"
                android:textAllCaps="false"
                android:textColor="@color/textDark"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_input_rounded"
                app:backgroundTint="@null"
                app:elevation="1dp"
                app:layout_constraintTop_toBottomOf="@id/btnSalesList"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavAdmin"
        android:layout_width="0dp"
        android:layout_height="80dp"
        android:background="#F3F5F6"
        app:menu="@menu/menu_admin_bottom"
        app:itemIconTint="@color/bottom_nav_colors"
        app:itemTextColor="#49454F"
        app:itemActiveIndicatorStyle="@style/BottomNavActiveIndicator"
        app:labelVisibilityMode="labeled"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
